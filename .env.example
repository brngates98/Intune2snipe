# Copy to .env for local runs (optional). python-dotenv loads .env automatically.
# Do not commit real secrets.

# Microsoft Entra ID (Azure AD) app registration
AZURE_TENANT_ID=your-tenant-guid
AZURE_CLIENT_ID=your-client-id

# Use EITHER a client secret OR a certificate (PEM) for Graph authentication.
AZURE_CLIENT_SECRET=your-client-secret

# Certificate auth (alternative to AZURE_CLIENT_SECRET):
# AZURE_COMBINED_CERT_KEY="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Or split:
# AZURE_CERTIFICATE_PEM=-----BEGIN CERTIFICATE-----...
# AZURE_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----...

# Snipe-IT API (HTTPS; normalized to .../api/v1 if the suffix is omitted)
SNIPEIT_URL=https://your-snipeit.example.com/api/v1
SNIPEIT_API_TOKEN=your-snipe-api-token
SNIPEIT_DEFAULT_STATUS=Ready to Deploy

# Optional: comma-separated Azure AD group object IDs (UUIDs)
# AZURE_GROUP_IDS=aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee

# Optional: allow https://10.x/ style URLs when Snipe is reached by IP
# SNIPEIT_ALLOW_PRIVATE_IP=1
